# MCP server display name used in generated install commands for all clients.
# Defaults to "prompts.chat" if not set.
NEXT_PUBLIC_MCP_SERVER_NAME=my-prompts-server

# NPM package name for local (stdio) MCP installs.
# Defaults to "@fkadev/prompts.chat-mcp" if not set.
NEXT_PUBLIC_MCP_NPM_PACKAGE=@fkadev/prompts.chat-mcp
